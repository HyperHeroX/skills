  "license": "MIT",
  "commands": [
    "./commands/"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/devteam-stop-hook.mjs"
          }
        ]
      }
    ]
  }
}
