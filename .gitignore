# HyperHeroX Skills Repository - Git Ignore

# ========================================
# 只提交 devtem skill，忽略其他目錄
# ========================================

# 忽略所有目錄（除了 devtem）
.agent/
.cursor/
.kilocode/
.vscode/
data/
openspec/

# 忽略 docs（保留格式範例在 devtem/reference 中）
docs/

# 保留的項目（明確列出不忽略）
# !devtem/
# !.github/
# !README.md
# !AGENTS.md
# !.gitignore

# ========================================
# 通用忽略規則
# ========================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor/IDE
*.swp
*.swo
*~
.idea/
*.sublime-workspace
*.sublime-project

# Logs
*.log
npm-debug.log*

# Temporary files
*.tmp
*.temp
.cache/

# Local state files (devtem runtime)
*.local.md
*.local.json

# Build outputs
dist/
build/
out/

# Dependencies
node_modules/
.pnpm-store/

# Environment files with secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
