{
  "schema_version": "1.0.0",
  "description": "Circuit breaker state template for devtem skill - prevents runaway loops",
  
  "state": "CLOSED",
  "consecutive_no_progress": 0,
  "consecutive_same_error": 0,
  "last_error_hash": null,
  "last_progress_step": 0,
  "total_opens": 0,
  "last_transition_at": null,
  "last_transition_reason": null,
  
  "thresholds": {
    "no_progress_threshold": 3,
    "same_error_threshold": 5,
    "half_open_threshold": 2
  },
  
  "state_descriptions": {
    "CLOSED": "Normal operation - all systems go",
    "HALF_OPEN": "Monitoring mode - watching for recovery or further stagnation",
    "OPEN": "Halted - requires user intervention to continue"
  },
  
  "transitions": {
    "CLOSED_to_HALF_OPEN": "consecutive_no_progress >= 2",
    "HALF_OPEN_to_CLOSED": "progress_detected (files modified or tasks completed)",
    "HALF_OPEN_to_OPEN": "no_progress_detected in HALF_OPEN state",
    "CLOSED_to_OPEN": "consecutive_no_progress >= 3 OR consecutive_same_error >= 5",
    "OPEN_to_CLOSED": "user 'continue' or 'reset circuit breaker' command"
  }
}
